# ===========================================
# Zomato Platform - Environment Configuration
# ===========================================
# Copy this file for each environment:
#   cp .env.example .env.dev    (development)
#   cp .env.example .env.qa     (QA / staging)
#   cp .env.example .env.prod   (production)
#
# The deploy script auto-selects the right file:
#   ./deploy.sh all latest prod  → uses .env.prod
#   ./deploy.sh all latest qa    → uses .env.qa
#   ./deploy.sh all latest dev   → uses .env.dev
#
# Fallback: if .env.<env> doesn't exist, .env is used
#
# NEVER commit real secrets to git
# ===========================================

# Docker Registry
DOCKER_REGISTRY=docker.io/umesa123
IMAGE_TAG=latest

# PostgreSQL
POSTGRES_USER=zomato
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# MongoDB
MONGO_USER=zomato
MONGO_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# RabbitMQ
RABBITMQ_USER=zomato
RABBITMQ_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_64

# Public-facing URLs (used by frontends via NEXT_PUBLIC_*)
PUBLIC_API_URL=http://localhost:8080
PUBLIC_CHAT_URL=http://localhost:8087

# Email (for health-check-ui alerts)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_TO=alerts@your-domain.com

# Anthropic (for chat-service AI features)
ANTHROPIC_API_KEY=sk-ant-xxx
