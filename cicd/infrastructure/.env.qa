# ===========================================
# Zomato Platform - QA Environment
# ===========================================
# Copy to /opt/zomato/.env.qa on the QA server
# ===========================================

# Docker Registry
DOCKER_REGISTRY=docker.io/umesa123
IMAGE_TAG=latest

# PostgreSQL
POSTGRES_USER=zomato
POSTGRES_PASSWORD=CHANGE_ME_QA_PASSWORD

# MongoDB
MONGO_USER=zomato
MONGO_PASSWORD=CHANGE_ME_QA_PASSWORD

# Redis
REDIS_PASSWORD=CHANGE_ME_QA_PASSWORD

# RabbitMQ
RABBITMQ_USER=zomato
RABBITMQ_PASSWORD=CHANGE_ME_QA_PASSWORD

# JWT
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_64

# Public URLs (update to match QA server hostname)
PUBLIC_API_URL=http://qa.zomato.local:8080
PUBLIC_CHAT_URL=http://qa.zomato.local:8087

# Email (for QA alert testing)
EMAIL_USER=your-qa-email@gmail.com
EMAIL_PASSWORD=your-qa-app-password
EMAIL_TO=qa-alerts@your-domain.com

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxx
