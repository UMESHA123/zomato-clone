# ===========================================
# Zomato Platform - PRODUCTION Environment
# ===========================================
# Copy to /opt/zomato/.env.prod on the prod server
# NEVER commit real values to git
# ===========================================

# Docker Registry
DOCKER_REGISTRY=docker.io/umesa123
IMAGE_TAG=latest

# PostgreSQL
POSTGRES_USER=zomato
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# MongoDB
MONGO_USER=zomato
MONGO_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# RabbitMQ
RABBITMQ_USER=zomato
RABBITMQ_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_64

# Public URLs (update to match production domain)
PUBLIC_API_URL=https://api.zomato.yourdomain.com
PUBLIC_CHAT_URL=https://chat.zomato.yourdomain.com

# Email (for production alerts)
EMAIL_USER=alerts@your-domain.com
EMAIL_PASSWORD=your-production-app-password
EMAIL_TO=oncall@your-domain.com

# Anthropic (for chat-service AI features)
ANTHROPIC_API_KEY=sk-ant-xxx
