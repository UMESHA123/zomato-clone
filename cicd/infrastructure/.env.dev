# ===========================================
# Zomato Platform - DEV Environment
# ===========================================
# Copy to /opt/zomato/.env.dev on the dev server
# ===========================================

# Docker Registry
DOCKER_REGISTRY=docker.io/umesa123
IMAGE_TAG=latest

# PostgreSQL (use weaker passwords for dev)
POSTGRES_USER=zomato
POSTGRES_PASSWORD=zomato_dev_secret

# MongoDB
MONGO_USER=zomato
MONGO_PASSWORD=zomato_dev_secret

# Redis
REDIS_PASSWORD=zomato_dev_secret

# RabbitMQ
RABBITMQ_USER=zomato
RABBITMQ_PASSWORD=zomato_dev_secret

# JWT
JWT_SECRET=zomato-jwt-dev-secret-not-for-production

# Public URLs (update to match dev server hostname)
PUBLIC_API_URL=http://dev.zomato.local:8080
PUBLIC_CHAT_URL=http://dev.zomato.local:8087

# Email (disabled in dev)
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_TO=

# Anthropic (optional in dev)
ANTHROPIC_API_KEY=
